# ============================================================
# COLORFUL CANVAS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Admin panel password (CHANGE THIS!)
ADMIN_PASSWORD=changeme123

# Flask session secret key (CHANGE THIS — use a long random string!)
SECRET_KEY=change-this-to-a-long-random-secret-key-2026

# Ayrshare API key for social media cross-posting
# Get your free key at: https://www.ayrshare.com
# Leave empty to disable social posting (files will be saved locally)
AYRSHARE_API_KEY=

# Server settings (defaults work fine for Pi Zero W)
HOST=0.0.0.0
PORT=5000
DEBUG=false
